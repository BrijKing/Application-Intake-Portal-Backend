package com.example.backend.controller;

import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RestController;

import com.example.backend.config.CsrfTokenGeneratorConfig;

import jakarta.servlet.http.HttpServletRequest;
import jakarta.servlet.http.HttpServletResponse;

@RestController
public class CreateCsrfToken {
	
	@GetMapping("/csrf")
	public void generate(HttpServletRequest req, HttpServletResponse res) {
				CsrfTokenGeneratorConfig.addCsrfTokenCookie(req, res);
	}

}
